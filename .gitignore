# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Virtual envs
.venv/
venv/

# Editor / tool state. The .vscode directory is ignored so per-user
# workspace state (e.g. argv.json, MCP server configs, workspace
# trust) never leaks, but the two shared config files below are
# committed so anyone opening the project in VS Code gets a working
# Python + ruff setup without manual config.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
.pytest_cache/
.mypy_cache/
.ruff_cache/
.claude/

# Secrets (keep .env.example committed)
.env
.env.*
!.env.example

# Local user config (tuned for the private 2026-06-07 sample corpus)
text-theme-analyzer.yml
text-theme-analyzer.local.yml

# Outputs (generated artifacts — never commit run results)
text-theme-output/
text-theme-output-llm/
out/
reports/

# Caches
.cache/

# Private note corpora — safety net so a future
# `text-theme-analyzer-sample-YYYY-MM-DD` folder can never be committed
text-theme-analyzer-sample-*/
text-theme-analyzer-sample-*/

# The full Obsidian vault used for real-corpus runs
data/

# OS
.DS_Store
Thumbs.db
