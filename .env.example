# Copy to .env and fill in your key.
# These are read by the CLI; you can also export them in your shell.
# The CLI auto-loads `.env` from the working directory (and walks up) at
# startup, so running the analyzer with no extra setup picks these up.
# Explicitly exported vars in your shell take precedence over the file.

# Ollama Pro (default provider)
TEXTHEME_OLLAMA_API_KEY=
TEXTHEME_OLLAMA_BASE_URL=https://ollama.com
TEXTHEME_OLLAMA_MODEL=gpt-oss:20b
TEXTHEME_OLLAMA_TIMEOUT=120

# Swap to any OpenAI-compatible endpoint (OpenAI, Groq, Together, …)
TEXTHEME_OPENAI_COMPAT_BASE_URL=
TEXTHEME_OPENAI_COMPAT_API_KEY=
TEXTHEME_OPENAI_COMPAT_MODEL=

# Cache + logging
TEXTHEME_CACHE_DIR=
TEXTHEME_LOG_LEVEL=INFO
